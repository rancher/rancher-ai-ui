+**Selectors**:
+- `cy.get('body').trigger('keydown', { altKey: true, key: 'k', keyCode: 75, bubbles: true, cancelable: true })`
+- `[data-testid="rancher-ai-ui-chat-container"]`
+- `[data-testid="rancher-ai-ui-chat-panel-ready"]`
